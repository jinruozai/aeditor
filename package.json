{
  "name": "@gooooo/editorframe",
  "version": "1.1.0",
  "description": "Blender-style dock layout UI framework — zero build, zero dependencies, pure IIFE. Drop-in <script> tag, everything hangs on window.EF.",
  "main": "dist/ef.js",
  "style": "dist/ef.css",
  "files": [
    "dist",
    "src",
    "tools",
    "tests",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "keywords": [
    "dock",
    "layout",
    "panel",
    "split",
    "editor-ui",
    "blender",
    "godot",
    "iife",
    "zero-build",
    "zero-dependency",
    "ui-framework",
    "frontend"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://gitee.com/lazygoo/editor-frame.git"
  },
  "homepage": "https://gitee.com/lazygoo/editor-frame",
  "bugs": {
    "url": "https://gitee.com/lazygoo/editor-frame/issues"
  },
  "author": "gooooo",
  "license": "MIT",
  "scripts": {
    "build": "node tools/build.mjs",
    "watch": "node tools/build.mjs --watch",
    "check": "node tools/check-syntax.mjs && node tests/signal.test.mjs && node tests/tree.test.mjs && node tests/theme.test.mjs",
    "check:dist": "node tools/check-bundle.mjs",
    "check:gde": "node tools/check-gde.mjs"
  },
  "sideEffects": [
    "dist/ef.css",
    "dist/ef.js"
  ]
}
